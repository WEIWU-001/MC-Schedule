# ==================== Flask 安全配置 ====================
# Flask 密钥（用于 session 加密等），请修改为随机字符串
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-me-32-hex-chars-minimum

# ==================== 超级管理员配置 ====================
# 自动创建此账号，如已存在则自动升级权限
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2024!
ADMIN_EMAIL=admin@example.com

# ==================== 网站配置 ====================
SITE_DOMAIN=http://127.0.0.1:5000

# ==================== 邮箱池配置 ====================
# 支持多个邮箱，按序号配置
# 邮箱 1
EMAIL_1_NAME=主邮箱
EMAIL_1_USERNAME=your-email@example.com
EMAIL_1_PASSWORD=your-email-password
EMAIL_1_SMTP_SERVER=smtp.example.com
EMAIL_1_SMTP_PORT=465
EMAIL_1_MAX_DAILY=500

# 邮箱 2（可选）
# EMAIL_2_NAME=副邮箱
# EMAIL_2_USERNAME=your-email2@example.com
# EMAIL_2_PASSWORD=your-email2-password
# EMAIL_2_SMTP_SERVER=smtp.example.com
# EMAIL_2_SMTP_PORT=465
# EMAIL_2_MAX_DAILY=500

# ==================== 腾讯云内容审核 (TMS) 配置 ====================
# 如不使用内容审核，可留空
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TMS_FREE_LIMIT=3000

# ==================== 系统更新配置 ====================
# 远程仓库地址（用于系统更新功能）
REMOTE_REPO_URL=https://github.com/WEIWU-001/MC-Schedule.git
# 默认分支
DEFAULT_BRANCH=main
